{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://2177.tech/protocol/supernova.three-species-vote.schema.json",
  "title": "SuperNova Three-Species Vote Result",
  "description": "A portable read-only vote result shape for human, AI, and company participation. This schema records decision state; it does not execute decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "proposal_id", "species", "result", "execution"],
  "properties": {
    "schema": {
      "const": "supernova.three_species_vote.v1"
    },
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_id": {
      "type": "string"
    },
    "species": {
      "type": "array",
      "prefixItems": [
        { "const": "human" },
        { "const": "ai" },
        { "const": "company" }
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["human", "ai", "company"],
      "properties": {
        "human": { "$ref": "#/$defs/speciesResult" },
        "ai": { "$ref": "#/$defs/speciesResult" },
        "company": { "$ref": "#/$defs/speciesResult" }
      }
    },
    "threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "deadline": {
      "type": "string",
      "format": "date-time"
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_current_mode", "automatic_execution", "company_ratification_required"],
      "properties": {
        "execution_current_mode": {
          "const": "manual_preview_only"
        },
        "automatic_execution": {
          "type": "boolean",
          "const": false
        },
        "company_ratification_required": {
          "type": "boolean",
          "const": true
        }
      }
    }
  },
  "$defs": {
    "speciesResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "enum": ["pending", "passed", "failed", "abstained", "not_applicable"]
        },
        "yes": {
          "type": "number",
          "minimum": 0
        },
        "no": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
